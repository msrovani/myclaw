package views

templ Layout(title string) {
	<!DOCTYPE html>
	<html lang="en" data-theme="dark">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>{ title } - XXXCLAW Admin</title>
			<!-- HTMX -->
			<script src="https://unpkg.com/htmx.org@1.9.10" integrity="sha384-D1Kt99CQMDuVetoL1lrYwg5t+9QdHe7NLX/SoJYkXDFfX37iInKRy5xLSi8nO7UC" crossorigin="anonymous"></script>
			<!-- Alpine.js -->
			<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
			<!-- ECharts -->
			<script src="https://cdn.jsdelivr.net/npm/echarts@5.5.0/dist/echarts.min.js"></script>
			<!-- CSS -->
			<style>
				:root {
					--bg: #0f172a;
					--surface: #1e293b;
					--border: #334155;
					--text: #f8fafc;
					--text-dim: #94a3b8;
					--primary: #0ea5e9;
					--success: #10b981;
					--danger: #ef4444;
					--warning: #f59e0b;
				}
				body {
					margin: 0;
					font-family: system-ui, -apple-system, sans-serif;
					background-color: var(--bg);
					color: var(--text);
					display: flex;
					min-height: 100vh;
				}
				nav {
					width: 250px;
					background: var(--surface);
					border-right: 1px solid var(--border);
					padding: 1.5rem;
					flex-shrink: 0;
				}
				nav h1 {
					font-size: 1.25rem;
					margin-top: 0;
					margin-bottom: 2rem;
					color: var(--primary);
					text-transform: uppercase;
					letter-spacing: 0.1em;
				}
				nav a {
					display: block;
					color: var(--text-dim);
					text-decoration: none;
					padding: 0.75rem 1rem;
					border-radius: 0.375rem;
					margin-bottom: 0.5rem;
					transition: all 0.2s;
				}
				nav a:hover, nav a.active {
					background: var(--bg);
					color: var(--primary);
				}
				main {
					flex: 1;
					padding: 2rem;
					overflow-y: auto;
				}
				.panel {
					background: var(--surface);
					border: 1px solid var(--border);
					border-radius: 0.5rem;
					padding: 1.5rem;
					margin-bottom: 1.5rem;
				}
				.grid-2 {
					display: grid;
					grid-template-columns: 1fr 1fr;
					gap: 1.5rem;
				}
				.metric-card {
					display: flex;
					flex-direction: column;
				}
				.metric-val {
					font-size: 2rem;
					font-weight: bold;
					color: var(--primary);
				}
				.metric-label {
					font-size: 0.875rem;
					color: var(--text-dim);
					text-transform: uppercase;
					letter-spacing: 0.05em;
				}
			</style>
		</head>
		<body hx-boost="true">
			<nav>
				<h1>XXXCLAW</h1>
				<a href="/" hx-target="main" hx-push-url="true">System Overview</a>
				<a href="/tokens" hx-target="main" hx-push-url="true">Tokens &amp; Cost</a>
				<a href="/memory" hx-target="main" hx-push-url="true">Memory</a>
				<a href="/router" hx-target="main" hx-push-url="true">LLM Router</a>
				<a href="/skills" hx-target="main" hx-push-url="true">Skills Runtime</a>
				<a href="/admin" hx-target="main" hx-push-url="true">Admin Controls</a>
			</nav>
			<main>
				{ children... }
			</main>
		</body>
	</html>
}
